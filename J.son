{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/api-server/dist",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.js"
    }
  ]
}
